                },
                "nasname": {
                    "type": "string"
                },
                "ports": {
                    "type": "integer"
                },
                "secret": {
                    "type": "string"
                },
                "server": {
                    "type": "string"
                },
                "shortname": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
