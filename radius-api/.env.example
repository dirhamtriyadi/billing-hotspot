# =============================================================================
#  RADIUS stack environment. Used by BOTH:
#   • `go run ./cmd/api`   (read directly via godotenv) — uses DB_HOST below
#   • `docker compose up`  (this folder's compose: mariadb + radius-api +
#                          freeradius) — DB_HOST is forced to the `mariadb`
#                          service; the NAS_* / MARIADB_* vars feed FreeRADIUS.
#  Copy to `.env`. Register this API_KEY in backend admin:
#  Radius Server → Radius API Key.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=Radius API
APP_ENV=development
APP_PORT=8081

# ── MariaDB / MySQL (FreeRADIUS database) ─────────────────────────────────
# DB_HOST applies to local `go run`. Under docker compose it is ignored (the
# radius-api container always talks to the `mariadb` service on hotspot-net).
DB_HOST=localhost
DB_PORT=3306
DB_USER=radius
DB_PASSWORD=radius
DB_NAME=radius
DB_PARAMS=charset=utf8mb4&parseTime=True&loc=Local
# Only used by docker compose (MariaDB container root password).
MARIADB_ROOT_PASSWORD=rootsecret

# ── Auth ──────────────────────────────────────────────────────────────────
# Shared secret the billing backend must send as the X-API-Key header.
# This may be unique per branch and only needs to match the corresponding
# Radius Server record in the backend admin UI.
API_KEY=radius-shared-secret

# ── CoA / Packet of Disconnect ────────────────────────────────────────────
COA_PORT=3799             # NAS CoA listen port (Mikrotik default)
COA_TIMEOUT=5s

# ── FreeRADIUS auto-reload (docker compose only) ──────────────────────────
# After a NAS is added/changed/removed, radius-api restarts the FreeRADIUS
# container so the new router (with its own secret) is recognised immediately.
# Needs the Docker socket mounted (see docker-compose.yml). Empty = disabled
# (you would then restart FreeRADIUS manually). Ignored by local `go run`.
FREERADIUS_CONTAINER=radius-freeradius
DOCKER_SOCKET=/var/run/docker.sock

# ── FreeRADIUS clients (docker compose only) ──────────────────────────────
# NAS_SHARED_SECRET secures localhost/radtest and the OPTIONAL subnet fallback
# in clients.conf (disabled by default — per-router secrets from the panel are
# preferred). RADIUS_DEBUG=yes runs FreeRADIUS in verbose (-x) mode.
NAS_SHARED_SECRET=mikrotik-secret
NAS_CLIENT_SUBNET=0.0.0.0/0
RADIUS_DEBUG=no

# ── CORS (for the radius-api Swagger UI) ──────────────────────────────────
CORS_ALLOWED_ORIGINS=*
