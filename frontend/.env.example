# Backend HOST only (scheme + host + port, NO path). The "/api/v1" version
# prefix is added in code (src/lib/api.ts API_VERSION), so this stays a pure
# host and bumping the API version doesn't need a deploy-config change.
# Baked into the build (Vite), so changing it requires a frontend rebuild.
VITE_API_BASE_URL=http://localhost:8080

# Hotspot gateway IP — used by the "Hubungkan Sekarang" one-tap login button on
# the voucher page (POSTs the code to http://<gateway>/login). Must match the
# hsGateway in the Mikrotik setup script (default 10.5.50.1). Baked at build.
VITE_HOTSPOT_GATEWAY=10.5.50.1

# Host port the nginx container is published on (docker compose only).
FRONTEND_PORT=8088
