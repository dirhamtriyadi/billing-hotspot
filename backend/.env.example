# =============================================================================
#  Backend environment. Used by BOTH:
#   • `go run ./cmd/api`   (read directly via godotenv) — uses DB_HOST below
#   • `docker compose up`  (this folder's compose) — DB_HOST is forced to the
#                          `postgres` service, the rest of the values are reused.
#  Copy to `.env` and adjust. Radius endpoints are managed from
#  Admin → Radius Server, not from backend env.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=Billing Hotspot
APP_ENV=development                       # development | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080        # public URL of THIS backend (gateway callbacks)
FRONTEND_URL=http://localhost:5173        # public URL of the SPA (post-payment redirect)

# ── PostgreSQL (billing database) ─────────────────────────────────────────
# DB_HOST applies to local `go run`. Under docker compose it is ignored (the
# backend container always talks to the `postgres` service on hotspot-net).
DB_HOST=localhost
DB_PORT=5432
DB_USER=billing
DB_PASSWORD=billing
DB_NAME=billing_hotspot
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=please-change-this-to-a-long-random-string-min-32-chars
JWT_ISSUER=billing-hotspot
JWT_ACCESS_TTL=24h

# ── Radius Server client ──────────────────────────────────────────────────
# Endpoint URL/key are stored in Admin → Radius Server. This timeout is used
# when backend calls any registered radius-api endpoint.
RADIUS_API_TIMEOUT=10s

# ── CORS ──────────────────────────────────────────────────────────────────
# Daftar origin SPA yang diizinkan (pisah koma). HARUS berisi URL frontend yang
# kamu buka di browser. Default Docker menyajikan frontend di :8088.
# Jangan pakai "*" — middleware mengirim Allow-Credentials sehingga wildcard
# ditolak browser. Tambahkan IP/domain publik bila diakses dari jaringan lain.
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:5173
